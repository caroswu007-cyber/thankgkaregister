# 复制为 .env 后填写（切勿提交 .env 到公开仓库）

# 与前端 js/sync-config.js 中 tencentProxySecret 一致
WEBHOOK_SECRET=请改为长随机串

# 腾讯文档开放平台：OAuth 换 token 后得到的访问令牌（会过期，见文档用 refresh_token 刷新）
TENCENT_ACCESS_TOKEN=

# 开放平台应用 Client ID
TENCENT_CLIENT_ID=

# OAuth 返回的 user_id，即 Open-Id
TENCENT_OPEN_ID=

# 智能表 fileID（文档 ID）、子表 sheetID（在开放平台或调试工具中可查）
TENCENT_FILE_ID=
TENCENT_SHEET_ID=

# 学员查询接口返回的「本期课程」展示文案（可选）
# QUERY_CURRENT_COURSE_LINE=唐卡传承公益体验课（2026年4月8日 — 4月12日）

PORT=8787
# 监听地址，默认 0.0.0.0；若仅本机可改为 127.0.0.1
HOST=0.0.0.0
